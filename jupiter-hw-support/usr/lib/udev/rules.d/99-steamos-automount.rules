# We need to filter only partitions from external usb devices here, otherwise
# internal partitions from other drives will be mounted, which can lead to things
# like windows ntfs recovery paritions or EFI boot partitions getting mounted

# The service expects to be asynchronous and shouldn't block udev rules
KERNEL=="mmcblk[0-9]p[0-9]", ACTION=="add",    RUN+="/bin/systemctl start --no-block steamos-automount@%k.service"
KERNEL=="mmcblk[0-9]p[0-9]", ACTION=="remove", RUN+="/bin/systemctl stop  --no-block steamos-automount@%k.service"

# Some devices register as ata devices over USB dock, check for by-id/usb-*
KERNEL=="sd[a-z][0-9]", ENV{ID_PATH}=="*-usb-*", ACTION=="add",    RUN+="/bin/systemctl start --no-block steamos-automount@%k.service"
KERNEL=="sd[a-z][0-9]", ENV{ID_PATH}=="*-usb-*", ACTION=="remove", RUN+="/bin/systemctl stop  --no-block steamos-automount@%k.service"

# Same thing for nvme devices connected via USB adapters/docks
KERNEL=="nvme[0-9]n[0-9]p[0-9]", ENV{ID_PATH}=="*-usb-*", ACTION=="add",    RUN+="/bin/systemctl start --no-block steamos-automount@%k.service"
KERNEL=="nvme[0-9]n[0-9]p[0-9]", ENV{ID_PATH}=="*-usb-*", ACTION=="remove", RUN+="/bin/systemctl stop  --no-block steamos-automount@%k.service"
